# Application
APP_NAME="Sistem Finansial Pendidikan"
APP_VERSION="1.0.0"
DEBUG=True
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256

# Token
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database
DATABASE_URL=sqlite:///./finansial.db
# DATABASE_URL=mysql+pymysql://root:password@localhost:3306/db_finansial_pendidikan

# Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=pdf,jpg,jpeg,png

# CORS
ALLOWED_ORIGINS=http://localhost,http://10.0.2.2
